llvm-mingw-*/
*.tar.xz
*.tar.gz

# ─── IDE / editors ────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp

# ─── AI assistants / local scratch ────────────────────────────
.claude/
.qoder/
.cursor/
.aider*
.env
.env.*

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
