# ─── Dart / Flutter ───────────────────────────────────────────
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
build/
pubspec.lock
doc/api/
coverage/
*.log

# ─── flutter_win runtime cache ────────────────────────────────
# Default location is $HOME/.flutter_win (see lib/src/cache_paths.dart).
# This guard covers `--cache-dir .flutter_win` used from inside the repo.
.flutter_win/

